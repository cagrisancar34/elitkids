PAYLOAD_SECRET=replace-with-a-long-random-secret-at-least-32-characters
CMS_ORIGIN_TOKEN=replace-with-a-different-random-secret-at-least-32-characters

# Koyeb production should use the Supabase Session Pooler on port 5432.
# The username must be the isolated payload_cms role (payload_cms.<project-ref>).
DATABASE_URI=postgres://payload_cms.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
PAYLOAD_DB_SCHEMA=public_cms

# Supabase Storage S3-compatible media storage. Required in production.
S3_ENABLED=true
S3_BUCKET=public-cms-media
S3_REGION=region
S3_ENDPOINT=https://project-ref.storage.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=replace-with-supabase-s3-access-key
S3_SECRET_ACCESS_KEY=replace-with-supabase-s3-secret-key
S3_PUBLIC_URL=https://project-ref.supabase.co/storage/v1/object/public/public-cms-media

NEXT_PUBLIC_SITE_URL=https://elitsanatvesporkulubu.com
NEXT_PUBLIC_CMS_ASSET_PREFIX=/cms-assets
NEXT_PUBLIC_WHATSAPP_NUMBER=905551112233
