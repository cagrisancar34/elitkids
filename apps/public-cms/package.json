{
  "name": "https-dortmevsimdogada-com-bu-sitenin-ayn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:next",
    "start": "next start",
    "lint": "eslint",
    "payload": "payload",
    "payload:types": "payload generate:types",
    "payload:importmap": "payload generate:importmap",
    "db:migrate": "payload migrate",
    "db:migrate:create": "payload migrate:create",
    "db:migrate:status": "payload migrate:status",
    "db:bootstrap": "NODE_OPTIONS=--conditions=react-server NODE_ENV=development tsx scripts/seed-public-site.ts",
    "seed:content-pages": "NODE_OPTIONS=--conditions=react-server tsx scripts/seed-content-pages.ts",
    "seed:public-site": "NODE_OPTIONS=--conditions=react-server tsx scripts/seed-public-site.ts",
    "test": "vitest run",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "build:next": "next build --webpack",
    "build:cloudflare": "NEXT_PUBLIC_CMS_ASSET_PREFIX=/cms-assets next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "preview": "npm run build:cloudflare && wrangler dev",
    "deploy": "npm run build:cloudflare && opennextjs-cloudflare deploy",
    "upload": "npm run build:cloudflare && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "cli-color": "^2.0.4",
    "graphql": "^16.14.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "payload": "^3.85.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.92.0"
  }
}
