{
  "name": "elitkids",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "guard:ga": "node scripts/require-public-env.mjs NEXT_PUBLIC_GA_ID=G-LQK7887YTE",
    "build:next": "next build --webpack",
    "build": "npm run guard:ga && npm run build:next && opennextjs-cloudflare build --skipNextBuild",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:security:bundle": "node scripts/security-secret-scan.mjs",
    "seed:demo": "node scripts/seed-supabase-demo.mjs",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "upload": "npm run build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.43.0"
  }
}
